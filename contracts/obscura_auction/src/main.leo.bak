    // ########################################################################
    //              T12: CLAIM WIN VICKREY (ALEO — second-price with refund)
    // ########################################################################

    async transition claim_win_vickrey(
        private bid: SealedBid,
        private receipt: EscrowReceipt,
        private seller_address: address,
        private item_hash: field,
        private second_price: u128
    ) -> (WinnerCertificate, SellerReceipt, credits.aleo/credits, credits.aleo/credits, Future) {
        assert_eq(bid.auction_id, receipt.auction_id);
        assert_eq(bid.bid_nonce, receipt.bid_nonce);
        assert_eq(bid.token_type, TOKEN_ALEO);
        assert(second_price <= bid.bid_amount);

        let bid_hash: field = BHP256::hash_to_field(BidCommitment {
            bidder: bid.owner,
            auction_id: bid.auction_id,
            amount: bid.bid_amount,
            nonce: bid.bid_nonce,
        });

        let fee: u128 = (second_price * PLATFORM_FEE_BPS) / FEE_DENOMINATOR;
        let seller_payout: u128 = second_price - fee;
        let winner_refund: u128 = bid.bid_amount - second_price;

        assert(seller_payout > 0u128);

        let payout_u64: u64 = seller_payout as u64;
        let refund_u64: u64 = winner_refund as u64;

        let (seller_credits, pay_future): (credits.aleo/credits, Future) =
            credits.aleo/transfer_public_to_private(
                seller_address,
                payout_u64
            );

        let (refund_credits, refund_future): (credits.aleo/credits, Future) =
            credits.aleo/transfer_public_to_private(
                self.caller,
                refund_u64
            );

        let cert: WinnerCertificate = WinnerCertificate {
            owner: self.caller,
            auction_id: bid.auction_id,
            item_hash: item_hash,
            winning_amount: second_price,
            token_type: TOKEN_ALEO,
            certificate_id: bid_hash,
        };

        let seller_receipt: SellerReceipt = SellerReceipt {
            owner: seller_address,
            auction_id: bid.auction_id,
            item_hash: item_hash,
            sale_amount: seller_payout,
            fee_paid: fee,
            token_type: TOKEN_ALEO,
        };

        return (cert, seller_receipt, seller_credits, refund_credits, finalize_claim_win_vickrey(
            pay_future, refund_future, bid.auction_id, bid_hash,
            bid.bid_amount, second_price, fee, item_hash
        ));
    }

    async function finalize_claim_win_vickrey(
        f0: Future,
        f1: Future,
        auction_id: field,
        bid_hash: field,
        bid_amount: u128,
        second_price: u128,
        fee: u128,
        item_hash: field
    ) {
        f0.await();
        f1.await();

        let auction: AuctionData = auctions.get(auction_id);
        assert_eq(auction.status, STATUS_SETTLED);
        assert_eq(auction.auction_mode, MODE_VICKREY);

        let winner_hash: field = auction_winners.get(auction_id);
        assert_eq(bid_hash, winner_hash);

        // Verify second_price matches stored second-highest
        let stored_second: u128 = second_highest_bids.get(auction_id);
        assert_eq(second_price, stored_second);

        // Ties use T10/T11, not T12 — bid must exceed second price
        assert(bid_amount > second_price);

        let revealed_amount: u128 = revealed_bids.get(bid_hash);
        assert_eq(revealed_amount, bid_amount);

        assert_eq(item_hash, auction.item_hash);

        let already_settled: bool = settlements.contains(auction_id);
        assert(!already_settled);
        settlements.set(auction_id, SettlementData {
            winner_bid_hash: bid_hash,
            final_price: second_price,
            fee_collected: fee,
            settled_at: block.height as u64,
        });

        let treasury: u128 = platform_treasury.get_or_use(0u8, 0u128);
        platform_treasury.set(0u8, treasury + fee);

        // Full bid_amount leaves program: seller_payout + fee + winner_refund
        let bal: u128 = program_balance.get(0u8);
        program_balance.set(0u8, bal - bid_amount);

        let escrow: u128 = auction_escrow.get(auction_id);
        auction_escrow.set(auction_id, escrow - bid_amount);
    }

    // ########################################################################
    //              T13: CLAIM WIN VICKREY (USDCx)
    // ########################################################################

    async transition claim_win_vickrey_usdcx(
