# Required — AES-256 encryption key for seller/bidder address storage
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# Frontend URL for CORS (production)
FRONTEND_URL=https://obscura-auction-95hm.vercel.app

# Server port (default: 3001)
PORT=3001

# Logging level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Supabase (optional — enables PostgreSQL storage + event sourcing)
# If not set, falls back to filesystem JSON storage
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here

# Upstash Redis (legacy — Supabase preferred)
# KV_REST_API_URL=https://your-redis.upstash.io
# KV_REST_API_TOKEN=your_token_here

# Aleo explorer API (default: https://api.explorer.provable.com/v1)
# EXPLORER_API=https://api.explorer.provable.com/v1

# Program ID (default: obscura_v3.aleo)
# PROGRAM_ID=obscura_v3.aleo
